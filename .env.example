# Tollgate Infrastructure Kit - Environment Configuration
# Copy this file to .env and fill in the values

# VPS Connection
VPS_IP=23.182.128.51
VPS_USER=debian
SSH_PRIVATE_KEY_FILE=~/.ssh/id_ed25519

# Domain Configuration
BASE_DOMAIN=example.com

# Cloudflare API
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_ZONE_ID=your_cloudflare_zone_id_here

# Shadowsocks (MPTCP server)
SHADOWSOCKS_PASSWORD=change_me_to_a_strong_password

# Cashu Mint
MINT_DOMAIN=mints.example.com
ACME_EMAIL=admin@example.com

# FIPS Mesh
FIPS_RELAY_URLS=wss://relay.damus.io,wss://nos.lol

# FIPS Exit Node (WireGuard upstream exit for mesh peers)
# Both optional — auto-generated on first deploy when left empty
# (Nostr nsec via openssl rand; WG peer keypair via wg genkey/pubkey).
# Supply your own to reuse an existing identity/peer.
FIPS_EXIT_PEER_PUBKEY=
FIPS_EXIT_NSEC=

# Obelisk Relay (NIP-29) - admin pubkey
OBELISK_ADMIN_NPUB=your_nostr_npub_here

# nsyte CLI (optional - for deploying nsites from the VPS)
NSYTE_PRIVATE_KEY=

# Routstr AI Inference Node
ROUTSTR_ADMIN_PASSWORD=change_me_to_a_strong_password
ROUTSTR_UPSTREAM_BASE_URL=https://api.z.ai/api/coding/paas/v4
ROUTSTR_UPSTREAM_API_KEY=your_zai_api_key_here
ROUTSTR_NODE_NAME="Tollgate AI Node"
ROUTSTR_NODE_DESCRIPTION="AI inference via Cashu micropayments"
ROUTSTR_LN_ADDRESS=
ROUTSTR_RECEIVE_LN_ADDRESS=you@wallet.com

# Auditable Voting (nsite keypair - generated on first deploy)
VOTING_NSEC=
VOTING_NPUB=

# ACT Runner (CI/CD for GRASP repos - generated on first deploy)
ACT_RUNNER_NSEC=
ACT_RUNNER_NPUB=

# Relatr (WoT - generated on first deploy)
RELATR_SERVER_SECRET_KEY=

# Strfry aggregation relay (auto-managed served set)
STRFRY_AGG_ROOT_NPUB=npub1c03rad0r6q833vh57kyd3ndu2jry30nkr0wepqfpsm05vq7he25slryrnw
STRFRY_AGG_SERVED_NPUBS=

# Restic dedup backup repository password (for incremental strfry/ngit snapshots)
BACKUP_RESTIC_PASSWORD=
