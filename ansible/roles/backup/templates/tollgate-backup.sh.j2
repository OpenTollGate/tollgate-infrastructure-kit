#!/bin/bash
set -euo pipefail

BACKUP_DIR="{{ backup_staging_dir }}"
TIMESTAMP=$(date +%F_%H%M%S)
RETENTION_DAYS={{ backup_retention_days }}

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1"
}

mkdir -p "$BACKUP_DIR"/{strfry,ngit-relay,grasp,mints,routstr,caddy}

log "Starting tollgate backup..."

# --- strfry export ---
if docker ps --format '{% raw %}{{.Names}}{% endraw %}' | grep -q '^{{ backup_strfry_container }}$'; then
    TMPFILE="$BACKUP_DIR/strfry/strfry_${TIMESTAMP}.jsonl.tmp"
    FINAL="$BACKUP_DIR/strfry/strfry_${TIMESTAMP}.jsonl"
    log "Exporting strfry..."
    if docker exec {{ backup_strfry_container }} /app/strfry export > "$TMPFILE"; then
        mv "$TMPFILE" "$FINAL"
        log "strfry export done: $FINAL"
    else
        rm -f "$TMPFILE"
        log "ERROR: strfry export failed"
    fi
else
    log "SKIP: strfry container not running"
fi

# --- ngit-relay export ---
if docker ps --format '{% raw %}{{.Names}}{% endraw %}' | grep -q '^{{ backup_ngit_relay_container }}$'; then
    TMPFILE="$BACKUP_DIR/ngit-relay/ngit_${TIMESTAMP}.jsonl.tmp"
    FINAL="$BACKUP_DIR/ngit-relay/ngit_${TIMESTAMP}.jsonl"
    log "Exporting ngit-relay..."
    if docker exec {{ backup_ngit_relay_container }} /app/strfry export > "$TMPFILE"; then
        mv "$TMPFILE" "$FINAL"
        log "ngit-relay export done: $FINAL"
    else
        rm -f "$TMPFILE"
        log "ERROR: ngit-relay export failed"
    fi
else
    log "SKIP: ngit-relay container not running"
fi

# --- GRASP git mirror ---
if [ -d "{{ backup_grasp_git_dir }}" ]; then
    log "Mirroring GRASP git repos..."
    rm -rf "$BACKUP_DIR/grasp/git"
    cp -a "{{ backup_grasp_git_dir }}" "$BACKUP_DIR/grasp/git"
    log "GRASP git mirror done"
else
    log "SKIP: GRASP git dir not found"
fi

# --- Mint SQLite databases ---
if [ -d "{{ backup_mints_dir }}" ]; then
    log "Copying mint databases..."
    rm -rf "$BACKUP_DIR/mints"/*
    find "{{ backup_mints_dir }}" -name '*.db' -exec bash -c 'mkdir -p "$BACKUP_DIR/mints/$(dirname "$1" | sed "s|{{ backup_mints_dir }}/\?||")" && cp "$1" "$BACKUP_DIR/mints/$(dirname "$1" | sed "s|{{ backup_mints_dir }}/\?||")/"' _ {} \;
    log "Mint databases copied"
else
    log "SKIP: mints dir not found"
fi

# --- Routstr data ---
if [ -d "{{ backup_routstr_dir }}" ]; then
    log "Copying Routstr data..."
    rm -rf "$BACKUP_DIR/routstr"/*
    cp -a "{{ backup_routstr_dir }}/." "$BACKUP_DIR/routstr/"
    log "Routstr data copied"
else
    log "SKIP: Routstr dir not found"
fi

# --- Caddy certs ---
if [ -d "{{ backup_caddy_dir }}" ]; then
    log "Copying Caddy certs..."
    rm -rf "$BACKUP_DIR/caddy"/*
    cp -a "{{ backup_caddy_dir }}/." "$BACKUP_DIR/caddy/"
    log "Caddy certs copied"
else
    log "SKIP: Caddy data dir not found"
fi

# --- Cleanup old backups ---
log "Cleaning up backups older than $RETENTION_DAYS days..."
find "$BACKUP_DIR" -name '*.jsonl' -type f -mtime +$RETENTION_DAYS -delete 2>/dev/null || true
find "$BACKUP_DIR" -name '*.tmp' -type f -mtime +1 -delete 2>/dev/null || true

log "Backup complete."
