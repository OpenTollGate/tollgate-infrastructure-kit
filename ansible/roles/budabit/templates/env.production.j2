VITE_APP_URL=https://{{ budabit_domain }}
VITE_APP_NAME={{ budabit_app_name }}
VITE_APP_ACCENT={{ budabit_app_accent }}
{% if budabit_app_logo | length > 0 %}
VITE_APP_LOGO={{ budabit_app_logo }}
{% else %}
VITE_APP_LOGO=https://{{ budabit_domain }}/logo.png
{% endif %}
{% if budabit_community_npub | length > 0 %}
VITE_DEFAULT_COMMUNITY={{ budabit_community_npub }}
{% endif %}
VITE_INDEXER_RELAYS={{ budabit_indexer_relays | join(',') }}
VITE_SIGNER_RELAYS={{ budabit_signer_relays | join(',') }}
VITE_GIT_RELAYS={{ budabit_git_relays | join(',') }}
VITE_DEFAULT_BLOSSOM_SERVERS={{ budabit_blossom_servers | join(',') }}
{% if budabit_cors_proxy | length > 0 %}
VITE_GIT_DEFAULT_CORS_PROXY={{ budabit_cors_proxy }}
{% endif %}
{% if budabit_default_pubkeys_hex | length > 0 %}
VITE_DEFAULT_PUBKEYS={{ budabit_default_pubkeys_hex }}
{% endif %}
FEATURE_GRASP={{ budabit_feature_grasp }}
FEATURE_CICD={{ budabit_feature_cicd }}
FEATURE_ALERTS={{ budabit_feature_alerts }}
NODE_ENV=production
