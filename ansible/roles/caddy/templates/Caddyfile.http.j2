{% if 'mint_orchestrator' in machine_roles and machine_active | default(true) %}
*.{{ mint_domain }} {
    tls {
        dns cloudflare {env.CF_API_TOKEN}
    }

    @test-mb host test-mb.{{ mint_domain }}
    handle @test-mb {
        reverse_proxy localhost:{{ mint_operator_proxy_port | default(3000) }}
    }

    @test-kb host test-kb.{{ mint_domain }}
    handle @test-kb {
        reverse_proxy localhost:{{ mint_operator_proxy_port | default(3000) }}
    }

    @test-gb host test-gb.{{ mint_domain }}
    handle @test-gb {
        reverse_proxy localhost:{{ mint_operator_proxy_port | default(3000) }}
    }

    @test-min host test-min.{{ mint_domain }}
    handle @test-min {
        reverse_proxy localhost:{{ mint_operator_proxy_port | default(3000) }}
    }

    @testnut-cdk host testnut-cdk.{{ mint_domain }}
    handle @testnut-cdk {
        reverse_proxy localhost:{{ mint_operator_proxy_port | default(3000) }}
    }

    @testnut-nutshell host testnut-nutshell.{{ mint_domain }}
    handle @testnut-nutshell {
        reverse_proxy localhost:{{ mint_operator_proxy_port | default(3000) }}
    }

    @testnut-compat host testnut-compat.{{ mint_domain }}
    handle @testnut-compat {
        reverse_proxy localhost:{{ mint_operator_proxy_port | default(3000) }}
    }

    @routstr-mint host routstr-mint.{{ mint_domain }}
    handle @routstr-mint {
        reverse_proxy localhost:{{ mint_operator_proxy_port | default(3000) }}
    }

    @print host print.{{ mint_domain }}
    handle @print {
        handle /api/* {
            reverse_proxy localhost:{{ mint_operator_proxy_port | default(3000) }}
        }
        handle /v1/* {
            reverse_proxy localhost:{{ mint_operator_proxy_port | default(3000) }}
        }
        handle {
            root * {{ tollgate_static_dir }}/cashu-brrr
            file_server
            try_files {path} /index.html
        }
    }

    @dashboard host dashboard.{{ mint_domain }}
    handle @dashboard {
        root * {{ tollgate_base_dir }}/mints-dashboard
        file_server
    }

    @bare_mints host {{ mint_domain }}
    handle @bare_mints {
        redir https://dashboard.{{ mint_domain }}{uri} permanent
    }

    handle {
        respond "Mint not found" 404
    }
}
{% endif %}

