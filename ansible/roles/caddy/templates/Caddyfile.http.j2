*.{{ mint_domain }} {
    tls {
        dns cloudflare {env.CF_API_TOKEN}
    }

    @test-mb host test-mb.{{ mint_domain }}
    handle @test-mb {
        reverse_proxy localhost:8085
    }

    @test-kb host test-kb.{{ mint_domain }}
    handle @test-kb {
        reverse_proxy localhost:8086
    }

    @test-gb host test-gb.{{ mint_domain }}
    handle @test-gb {
        reverse_proxy localhost:8087
    }

    @test-min host test-min.{{ mint_domain }}
    handle @test-min {
        reverse_proxy localhost:8088
    }

    @print host print.{{ mint_domain }}
    handle @print {
        handle /api/* {
            reverse_proxy localhost:{{ mint_operator_proxy_port | default(3000) }}
        }
        handle {
            root * {{ tollgate_static_dir }}/cashu-brrr
            file_server
            try_files {path} /index.html
        }
    }

    @dashboard host dashboard.{{ mint_domain }}
    handle @dashboard {
        root * {{ tollgate_base_dir }}/mints-dashboard
        file_server
    }

    handle {
        respond "Mint not found" 404
    }
}

{{ base_domain }} {
    log {
        output stdout
    }

    handle_path /relay/* {
        reverse_proxy localhost:{{ strfry_port }}
    }

    handle_path /chat/* {
        reverse_proxy localhost:{{ obelisk_port }}
    }

    handle_path /blossom/* {
        reverse_proxy localhost:{{ blossom_port }}
    }

    handle_path /nsite/* {
        reverse_proxy localhost:{{ nsite_gateway_port }}
    }

    handle_path /releases/* {
        root * {{ tollgate_static_dir }}/releases
        file_server
        try_files {path} /index.html
    }

    handle_path /ci/* {
        root * {{ tollgate_static_dir }}/hive-ci
        file_server
        try_files {path} /index.html
    }

    handle_path /git/* {
        reverse_proxy localhost:{{ grasp_port }}
    }

    handle / {
        respond "Tollgate Infrastructure Kit - Running" 200
    }

    handle {
        respond "Not found" 404
    }
}

:80 {
    handle {
        respond "Tollgate Infrastructure Kit" 200
    }
}
