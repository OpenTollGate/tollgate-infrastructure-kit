[Unit]
Description=Tollgate Auditable Voting Worker
After=network.target

[Service]
Type=simple
WorkingDirectory={{ voting_worker_state_dir }}
ExecStart={{ voting_worker_binary }}
Environment=WORKER_NSEC={{ worker_nsec.stdout }}
Environment=WORKER_STATE_DIR={{ voting_worker_state_dir }}
Environment=WORKER_RELAYS={{ voting_worker_relays | join(',') }}
Environment=COORDINATOR_NPUB={{ voting_worker_coordinator_npub }}
Environment=RUST_LOG=info
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
