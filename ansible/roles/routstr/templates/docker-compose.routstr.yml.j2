services:
  {{ routstr_container_name }}:
    image: {{ routstr_image }}
    container_name: {{ routstr_container_name }}
    restart: unless-stopped
    network_mode: host
    volumes:
      - {{ routstr_data_dir }}:/app/data
      - {{ routstr_log_dir }}:/app/logs
    environment:
      PORT: "{{ routstr_rest_port }}"
      DATABASE_URL: "sqlite+aiosqlite:////app/data/routstr.db"
      ADMIN_PASSWORD: "{{ routstr_admin_password }}"
      UPSTREAM_BASE_URL: "{{ routstr_upstream_base_url }}"
      UPSTREAM_API_KEY: "{{ routstr_upstream_api_key }}"
      NAME: "{{ routstr_node_name }}"
      DESCRIPTION: "{{ routstr_node_description }}"
      HTTP_URL: "https://{{ routstr_domain }}"
      CASHU_MINTS: "{{ routstr_mint_url }}"
      RELAYS: "{{ routstr_relays }}"
      NSEC: "{{ routstr_nsec }}"
      RECEIVE_LN_ADDRESS: "{{ routstr_ln_address }}"
      LOG_LEVEL: "info"
      CORS_ORIGINS: "*"
      TOR_PROXY_URL: "socks5://127.0.0.1:9050"

  {{ routstr_tor_container_name }}:
    image: {{ routstr_tor_image }}
    container_name: {{ routstr_tor_container_name }}
    restart: unless-stopped
    network_mode: host
    volumes:
      - {{ routstr_tor_dir }}:/var/lib/tor
    environment:
      HS_ROUTER: "127.0.0.1:{{ routstr_rest_port }}:80"
