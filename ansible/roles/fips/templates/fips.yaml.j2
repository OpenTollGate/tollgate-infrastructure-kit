# FIPS Node Configuration — managed by Ansible

node:
  identity:
    persistent: true
{% if fips_identity_nsec is defined and fips_identity_nsec | length > 0 %}
    nsec: "{{ fips_identity_nsec }}"
{% endif %}
  discovery:
    nostr:
      enabled: true
      policy: configured_only
      open_discovery_max_pending: 64
      app: "fips-overlay-v1"
      advertise: true
      advert_relays:
{% for relay in fips_advertise_relays %}
        - "{{ relay }}"
{% endfor %}
      dm_relays:
{% for relay in fips_dm_relays %}
        - "{{ relay }}"
{% endfor %}
      stun_servers:
        - "stun:stun.l.google.com:19302"
        - "stun:stun.cloudflare.com:3478"
        - "stun:global.stun.twilio.com:3478"

tun:
  enabled: true
  name: fips0
  mtu: 1280

dns:
  enabled: true
  port: 5354

transports:
  udp:
    bind_addr: "0.0.0.0:2121"
    advertise_on_nostr: true

  tcp:
    bind_addr: "0.0.0.0:8443"
    advertise_on_nostr: true

peers: []
