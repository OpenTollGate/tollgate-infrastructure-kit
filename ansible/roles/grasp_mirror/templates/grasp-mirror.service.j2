[Unit]
Description=GRASP Mirror Daemon
After=network.target ngit-grasp.service
Wants=ngit-grasp.service

[Service]
Type=simple
ExecStart=/usr/local/bin/grasp-mirror --config {{ grasp_mirror_data_dir }}/config.toml daemon
EnvironmentFile={{ grasp_mirror_data_dir }}/grasp-mirror.env
WorkingDirectory={{ grasp_mirror_data_dir }}
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
