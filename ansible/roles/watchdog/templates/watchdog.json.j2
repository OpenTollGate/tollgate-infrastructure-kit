{
  "check_interval": {{ watchdog_check_interval }},
  "ssh_timeout": {{ watchdog_ssh_timeout }},
  "http_timeout": {{ watchdog_http_timeout }},
  "cooldown": {{ watchdog_cooldown }},
  "machines": {
    "m1": {
      "ssh_host_env": "VPS_IP",
      "ssh_user_env": "VPS_USER",
      "ssh_key_env": "SSH_PRIVATE_KEY_FILE",
      "ssh_become_env": "VPS_PASSWORD",
      "ansible_host": "tollgate-vps"
    },
    "m2": {
      "ssh_host_env": "OLD_VPS_IP",
      "ssh_user_env": "OLD_VPS_USER",
      "ssh_key_env": "SSH_PRIVATE_KEY_FILE",
      "ssh_become_env": "OLD_VPS_PASSWORD",
      "ansible_host": "tollgate-vps-old"
    }
  },
  "services": [
    {"name": "caddy",             "url": "https://{{ base_domain }}",                              "playbook": "04-caddy.yml",            "machine": "m1"},
    {"name": "strfry-m1",         "url": "https://relay.{{ base_domain }}",                        "playbook": "05-strfry.yml",           "machine": "m1"},
    {"name": "obelisk",           "url": "https://chat.{{ base_domain }}",                         "playbook": "06-obelisk-relay.yml",    "machine": "m1"},
    {"name": "blossom",           "url": "https://blossom.{{ base_domain }}",                      "playbook": "07-blossom.yml",          "machine": "m1"},
    {"name": "nsite-gateway",     "url": "https://nsite.{{ base_domain }}",                        "playbook": "08-nsite-gateway.yml",    "machine": "m1"},
    {"name": "releases",          "url": "https://releases.{{ base_domain }}",                     "playbook": "09-release-explorer.yml", "machine": "m1"},
    {"name": "grasp",             "url": "https://git.{{ base_domain }}",                          "playbook": "15-grasp.yml",            "machine": "m1"},
    {"name": "test-mb-mint",      "url": "https://test-mb.mints.{{ base_domain }}/v1/info",        "playbook": "deploy-test-mints.yml",   "machine": "m1"},
    {"name": "test-kb-mint",      "url": "https://test-kb.mints.{{ base_domain }}/v1/info",        "playbook": "deploy-test-mints.yml",   "machine": "m1"},
    {"name": "test-gb-mint",      "url": "https://test-gb.mints.{{ base_domain }}/v1/info",        "playbook": "deploy-test-mints.yml",   "machine": "m1"},
    {"name": "test-min-mint",     "url": "https://test-min.mints.{{ base_domain }}/v1/info",       "playbook": "deploy-test-mints.yml",   "machine": "m1"},
    {"name": "cashu-brrr",        "url": "https://print.mints.{{ base_domain }}",                  "playbook": "16-cashu-brrr.yml",       "machine": "m1"},
    {"name": "mint-operator-proxy","url":"https://print.mints.{{ base_domain }}/api/health",       "playbook": "17-mint-operator-proxy.yml","machine": "m1"},
    {"name": "auditable-voting",  "url": "https://vote.{{ base_domain }}",                         "playbook": "17-auditable-voting.yml", "machine": "m1"},
    {"name": "routstr",           "url": "https://routstr.{{ base_domain }}/v1/models",            "playbook": "18-routstr.yml",          "machine": "m1"},
    {"name": "ngit-relay-m1",     "url": "https://ngit.{{ base_domain }}",                         "playbook": "19-ngit-relay.yml",       "machine": "m1"},
    {"name": "grasp-mirror",      "url": "https://git.{{ base_domain }}/api/mirror-health",        "playbook": "30-grasp-mirror.yml",     "machine": "m1"},
    {"name": "relatr",            "url": "https://wot.{{ base_domain }}",                          "playbook": "32-relatr.yml",           "machine": "m1"},

    {"name": "strfry-m2",         "url": "https://relay.m2.{{ base_domain }}",                     "playbook": "05-strfry.yml",           "machine": "m2"},
    {"name": "ngit-relay-m2",     "url": "https://ngit.m2.{{ base_domain }}",                      "playbook": "19-ngit-relay.yml",       "machine": "m2"},
    {"name": "vpn",               "url": "https://vpn.{{ base_domain }}/api/v1/status",            "playbook": "31-micro-vpn.yml",        "machine": "m2"}
  ],
  "groups": {
    "mints": ["test-mb-mint", "test-kb-mint", "test-gb-mint", "test-min-mint"],
    "m1-core": ["caddy", "strfry-m1", "blossom", "grasp"],
    "m2-core": ["strfry-m2", "ngit-relay-m2", "vpn"]
  }
}
