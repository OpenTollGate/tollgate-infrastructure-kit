[Unit]
Description=Bitcoin Core Node (Pruned, Low RAM)
After=network.target

[Service]
ExecStart=/usr/local/bin/bitcoind -conf={{ bitcoin_core_data_dir }}/bitcoin.conf -datadir={{ bitcoin_core_data_dir }}
Restart=always
RestartSec=10

MemoryHigh={{ bitcoin_core_memory_high }}
MemoryMax={{ bitcoin_core_memory_max }}
TasksMax=100
Nice=15
OOMScoreAdjust=500

[Install]
WantedBy=multi-user.target
