db = "{{ nip29_db_dir }}"

relay {
    bind = "{{ nip29_bind }}"
    port = {{ nip29_port }}
    nofiles = 524288
    realIpHeader = ""

    writePolicy {
        type = "callback"
        path = "{{ nip29_base_dir }}/strfry29"
    }

    negentropy {
        enabled = true
        maxSyncEvents = 1000000
    }
}
