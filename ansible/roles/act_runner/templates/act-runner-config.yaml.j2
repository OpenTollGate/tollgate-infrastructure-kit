repos:
{% for repo in act_runner_repos %}
  - url: "{{ repo.url }}"
    branch: "{{ repo.branch | default('main') }}"
{% if repo.pipeline is defined and repo.pipeline != 'act' %}
    pipeline: "{{ repo.pipeline }}"
{% endif %}
{% if repo.custom_command is defined and repo.custom_command %}
    custom_command: "{{ repo.custom_command }}"
{% endif %}
{% if repo.trigger is defined and repo.trigger != 'push' %}
    trigger: "{{ repo.trigger }}"
{% endif %}
{% else %}  []
{% endfor %}

poll_interval: {{ act_runner_poll_interval }}
db_path: {{ act_runner_db_path }}
work_dir: {{ act_runner_work_dir }}
log_dir: {{ act_runner_log_dir }}
artifact_dir: {{ act_runner_artifact_dir }}
act_binary: {{ act_runner_binary }}
api_host: 0.0.0.0
api_port: {{ act_runner_port }}
log_level: {{ act_runner_log_level }}
relays:
{% for relay in act_runner_relays %}
  - "{{ relay }}"
{% endfor %}
