[Interface]
PrivateKey = {{ fips_exit_peer_private_key }}
Address = {{ fips_exit_peer_tunnel_ip }}/24
MTU = {{ fips_exit_mtu }}
DNS = 1.1.1.1, 1.0.0.1

[Peer]
PublicKey = {{ fips_exit_server_public_key }}
Endpoint = {{ fips_exit_advert_endpoint }}
AllowedIPs = 0.0.0.0/0, ::/0
PersistentKeepalive = 25
