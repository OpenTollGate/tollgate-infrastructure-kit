{
  "check_interval": 120,
  "ssh_timeout": 10,
  "http_timeout": 10,
  "cooldown": 600,
  "ssh": {
    "host_env": "VPS_IP",
    "user_env": "VPS_USER",
    "key_env": "SSH_PRIVATE_KEY_FILE",
    "port": 22,
    "redeploy": ["02-docker.yml"]
  },
  "services": [
    {
      "name": "caddy",
      "url": "https://orangesync.tech",
      "playbook": "04-caddy.yml"
    },
    {
      "name": "strfry",
      "url": "https://relay.orangesync.tech",
      "playbook": "05-strfry.yml"
    },
    {
      "name": "obelisk",
      "url": "https://chat.orangesync.tech",
      "playbook": "06-obelisk-relay.yml"
    },
    {
      "name": "blossom",
      "url": "https://blossom.orangesync.tech",
      "playbook": "07-blossom.yml"
    },
    {
      "name": "nsite-gateway",
      "url": "https://nsite.orangesync.tech",
      "playbook": "08-nsite-gateway.yml"
    },
    {
      "name": "releases",
      "url": "https://releases.orangesync.tech",
      "playbook": "09-release-explorer.yml"
    },
    {
      "name": "grasp",
      "url": "https://git.orangesync.tech",
      "playbook": "15-grasp.yml"
    },
    {
      "name": "test-mb-mint",
      "url": "https://test-mb.mints.orangesync.tech/v1/info",
      "playbook": "deploy-test-mints.yml"
    },
    {
      "name": "test-kb-mint",
      "url": "https://test-kb.mints.orangesync.tech/v1/info",
      "playbook": "deploy-test-mints.yml"
    },
    {
      "name": "test-gb-mint",
      "url": "https://test-gb.mints.orangesync.tech/v1/info",
      "playbook": "deploy-test-mints.yml"
    },
    {
      "name": "test-min-mint",
      "url": "https://test-min.mints.orangesync.tech/v1/info",
      "playbook": "deploy-test-mints.yml"
    },
    {
      "name": "cashu-brrr",
      "url": "https://print.mints.orangesync.tech",
      "playbook": "16-cashu-brrr.yml"
    },
    {
      "name": "mint-operator-proxy",
      "url": "https://print.mints.orangesync.tech/api/health",
      "playbook": "17-mint-operator-proxy.yml"
    },
    {
      "name": "auditable-voting",
      "url": "https://vote.orangesync.tech",
      "playbook": "17-auditable-voting.yml"
    },
    {
      "name": "routstr",
      "url": "https://routstr.orangesync.tech/v1/models",
      "playbook": "18-routstr.yml"
    },
    {
      "name": "ngit-relay",
      "url": "https://ngit.{{ base_domain }}",
      "playbook": "19-ngit-relay.yml"
    },
    {
      "name": "services-status",
      "url": "https://services.{{ base_domain }}",
      "playbook": "04-caddy.yml"
    },
    {
      "name": "solix-nsite",
      "url": "https://solix.orangesync.tech",
      "playbook": "25-solix-nsite.yml"
    }
  ],
  "groups": {
    "mints": ["test-mb-mint", "test-kb-mint", "test-gb-mint", "test-min-mint"],
    "core": ["caddy", "strfry", "blossom"]
  }
}
